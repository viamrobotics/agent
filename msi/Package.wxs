<?xml version="1.0" encoding="UTF-8"?>

<!--
  Viam Agent MSI Installer

  What this handles declaratively:
    - Directory creation (RootPath\cache, RootPath\bin)
    - Windows service (viam-agent) with automatic start
    - Firewall inbound rule via WixFirewall

  What uses custom actions:
    - Download: curl.exe fetches the agent binary into cache\ at install time
    - Symlink: bin\viam-agent.exe -> cache\viam-agent-from-installer.exe
      (MSI has no native symlink support; we shell out to cmd /c mklink)
    - Service failure recovery (sc.exe failure config)
    - ServiceAccount mode (sc.exe config, icacls, secedit, event log source)

  Download (AGENTDOWNLOADURL property):
    - curl.exe (built-in since Win10 1803) downloads AGENTDOWNLOADURL into CACHEDIR
    - Default URL: GCS stable channel (same as windows-installer-agent.ps1)
    - Override: msiexec /i Package.msi AGENTDOWNLOADURL="https://..."

  ServiceAccount mode (SERVICEACCOUNT=1 property):
    - Switches service logon from LocalSystem to NT SERVICE\viam-agent
    - Grants NT SERVICE\viam-agent full control of ROOTDIR (C:\opt\viam)
    - Grants NT SERVICE\viam-agent read+execute on CONFIGDIR (default C:\etc)
    - Grants SeCreateSymbolicLinkPrivilege for self-update symlinks
    - Registers Application event log source so the non-admin account can write events

  TODOs (not yet implemented):
    - Rollback custom action for symlink removal on failed install
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">


  <Package Name="Viam Agent"
           Manufacturer="Viam Inc."
           Version="0.1.0"
           UpgradeCode="E7A14B3C-6D2F-4F8A-9B1E-3C5D7F9A2B4E"
           Scope="perMachine">

    <!-- Require admin privileges (the agent installs a service) -->
    <Launch Condition="Privileged" Message="This installer requires administrator privileges." />

    <!-- Major upgrade: remove older versions before installing -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Viam Agent is already installed." />

    <!-- Public properties forwarded to the execute sequence.
         AGENTDOWNLOADURL  URL for the agent binary; override on the command line.
         SERVICEACCOUNT=1  run as NT SERVICE\viam-agent instead of LocalSystem.
         ROOTPATH          install root; maps to ROOTDIR (default C:\opt\viam).
         CONFIGDIR         directory containing viam.json (default C:\etc).
                           Used to assemble \-\-config "[CONFIGDIR]\viam.json" and
                           as the ACL grant target in ServiceAccount mode. -->
    <Property Id="AGENTDOWNLOADURL" Value="https://storage.googleapis.com/packages.viam.com/apps/viam-agent/viam-agent-stable-windows-x86_64" />
    <Property Id="SERVICEACCOUNT" Value="0" />
    <Property Id="ROOTPATH" Value="C:\opt\viam" />
    <Property Id="CONFIGDIR" Value="C:\etc" />

    <!-- Override ROOTDIR from the ROOTPATH property so the install
         directory is configurable (msiexec /i ... ROOTPATH="D:\viam").
         Runs before CostInitialize in both UI and execute sequences so
         directory costing picks up the override. -->
    <SetProperty Id="ROOTDIR" Before="CostInitialize" Sequence="both" Value="[ROOTPATH]" />

    <!-- ================================================================
         Directory layout

         We install to C:\opt\viam by default. This is a custom path
         outside ProgramFiles, matching the ps1 installer's default.
         ================================================================ -->

    <!-- TARGETDIR is the MSI root (always C:\ on typical installs).
         We build C:\opt\viam\{cache,bin} from there. -->
    <StandardDirectory Id="TARGETDIR">
      <Directory Id="OPTDIR" Name="opt">
        <Directory Id="ROOTDIR" Name="viam">
          <Directory Id="CACHEDIR" Name="cache" />
          <Directory Id="BINDIR" Name="bin" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ================================================================
         Cache directory

         No file is bundled in the CAB for CACHEDIR — the agent binary is
         downloaded at install time by the DownloadAgent custom action.
         This component exists solely to:
           1. Force CACHEDIR creation (CreateFolder) before DownloadAgent runs.
           2. Remove the downloaded binary on uninstall (RemoveFile).
         ================================================================ -->

    <ComponentGroup Id="AgentCache" Directory="CACHEDIR">
      <Component Id="CacheDir" Guid="D4E5F6A7-B8C9-0123-DEAB-345678901234">
        <CreateFolder />
        <!-- Clean up the downloaded binary on uninstall.
             viam-agent-from-installer.exe is not tracked by a file component
             (it is downloaded by the DownloadAgent CA), so MSI won't remove it
             automatically; this RemoveFile entry bridges that gap. -->
        <RemoveFile Id="RemoveCachedAgent"
                    Name="viam-agent-from-installer.exe"
                    On="uninstall" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Download agent binary at install time

         curl.exe is built into Windows 10 1803+. The -fail flag causes a
         non-zero exit on HTTP 4xx/5xx, preventing a silent write of an error
         page. The -retry 3 flag retries on transient network failures.
         Runs after CreateFolders (CACHEDIR exists) and before InstallFiles.
         ================================================================ -->

    <SetProperty Id="DownloadAgent"
                 Before="DownloadAgent"
                 Sequence="execute"
                 Value="&quot;[System64Folder]curl.exe&quot; -L --fail --retry 3 -o &quot;[CACHEDIR]viam-agent-from-installer.exe&quot; &quot;[AGENTDOWNLOADURL]&quot;" />

    <CustomAction Id="DownloadAgent"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- ================================================================
         Symlink: bin\viam-agent.exe -> ..\cache\viam-agent-from-installer.exe

         MSI has no native symlink support. We use deferred CAs that
         run cmd.exe /c mklink / del. Deferred CAs run as SYSTEM with
         Impersonate="no", so mklink has the needed privileges.
         ================================================================ -->

    <!-- WixQuietExec64 runs as a DLL inside the msiexec.exe service process and
         inherits its full SYSTEM token (including SeCreateSymbolicLinkPrivilege).
         A Type-34 ExeCommand CA instead spawns a child process with a stripped
         MSI sandbox token that lacks that privilege, causing mklink to fail.
         SetProperty is an immediate action with access to all MSI properties;
         the formatted value is stored and later read as CustomActionData by the
         deferred WixQuietExec64 CA. -->

    <SetProperty Id="CreateSymlink"
                 Before="CreateSymlink"
                 Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c del /f &quot;[BINDIR]viam-agent.exe&quot; 2&gt;nul &amp; mklink &quot;[BINDIR]viam-agent.exe&quot; &quot;[CACHEDIR]viam-agent-from-installer.exe&quot;" />

    <CustomAction Id="CreateSymlink"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- Remove symlink on uninstall; ignore failures (file may already be gone) -->
    <SetProperty Id="RemoveSymlink"
                 Before="RemoveSymlink"
                 Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c del /f &quot;[BINDIR]viam-agent.exe&quot;" />

    <CustomAction Id="RemoveSymlink"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- Configure service failure actions: restart 3x with 5s delay.
         Runs after service is installed. -->
    <SetProperty Id="ConfigureServiceFailure"
                 Before="ConfigureServiceFailure"
                 Sequence="execute"
                 Value="&quot;[System64Folder]sc.exe&quot; failure &quot;viam-agent&quot; reset= 0 actions= restart/5000/restart/5000/restart/5000" />

    <CustomAction Id="ConfigureServiceFailure"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <SetProperty Id="ConfigureServiceFailureFlag"
                 Before="ConfigureServiceFailureFlag"
                 Sequence="execute"
                 Value="&quot;[System64Folder]sc.exe&quot; failureflag &quot;viam-agent&quot; 1" />

    <CustomAction Id="ConfigureServiceFailureFlag"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- ================================================================
         ConfigPath: update the service binary path to include \-\-config.

         ServiceInstall can only set a static Arguments string, so we
         use sc.exe config to append \-\-config after the service exists.
         The config file path is assembled from CONFIGDIR + viam.json.
         ================================================================ -->

    <SetProperty Id="SetServiceConfigPath"
                 Before="SetServiceConfigPath"
                 Sequence="execute"
                 Value="&quot;[System64Folder]sc.exe&quot; config &quot;viam-agent&quot; binPath= &quot;\&quot;[BINDIR]viam-agent.exe\&quot; --viam-dir \&quot;[ROOTDIR].\&quot; --config \&quot;[CONFIGDIR]viam.json\&quot;&quot;" />

    <CustomAction Id="SetServiceConfigPath"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- ================================================================
         VIAM_HOME environment variable on the service registry key.

         Sets the Environment REG_MULTI_SZ so child processes
         (viam-server, modules) inherit the correct root path.
         Mirrors the ps1: Set-ItemProperty … -Name "Environment"
                          -Value @("VIAM_HOME=$RootPath") -Type MultiString
         ================================================================ -->

    <SetProperty Id="SetViamHomeEnv"
                 Before="SetViamHomeEnv"
                 Sequence="execute"
                 Value="&quot;[System64Folder]reg.exe&quot; add &quot;HKLM\SYSTEM\CurrentControlSet\Services\viam-agent&quot; /v Environment /t REG_MULTI_SZ /d &quot;VIAM_HOME=[ROOTDIR].&quot; /f" />

    <CustomAction Id="SetViamHomeEnv"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- ================================================================
         ServiceAccount mode CAs (run only when SERVICEACCOUNT=1)

         Sequencing: all run after InstallServices (service must exist
         before switching the logon account and resolving its SID).

         secedit note: the GrantSymlinkPrivilege CA avoids all [...]
         .NET type syntax in the PowerShell -Command string because MSI's
         property formatter would expand [Foo.Bar] as property "Foo.Bar"
         (→ empty). Instead we use sc.exe showsid to get the SID,
         Get-Content/Set-Content instead of [IO.File], $env:TEMP instead
         of [IO.Path]::GetTempFileName(), and .* instead of [^\r\n]*.
         ================================================================ -->

    <SetProperty Id="SetServiceAccount"
                 Before="SetServiceAccount"
                 Sequence="execute"
                 Value="&quot;[System64Folder]sc.exe&quot; config &quot;viam-agent&quot; obj= &quot;NT SERVICE\viam-agent&quot;" />

    <CustomAction Id="SetServiceAccount"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- icacls "(OI)(CI)F" = full control, inherited by files and subdirs -->
    <SetProperty Id="GrantRootDirAcl"
                 Before="GrantRootDirAcl"
                 Sequence="execute"
                 Value="&quot;[System64Folder]icacls.exe&quot; &quot;[ROOTDIR].&quot; /grant &quot;NT SERVICE\viam-agent:(OI)(CI)F&quot;" />

    <CustomAction Id="GrantRootDirAcl"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- Create CONFIGDIR if it doesn't exist (mirrors ps1: New-Item -Force) -->
    <SetProperty Id="CreateConfigDir"
                 Before="CreateConfigDir"
                 Sequence="execute"
                 Value="&quot;[System64Folder]cmd.exe&quot; /c if not exist &quot;[CONFIGDIR]&quot; mkdir &quot;[CONFIGDIR]&quot;" />

    <CustomAction Id="CreateConfigDir"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- icacls "(OI)(CI)RX" = read+execute, inherited by files and subdirs -->
    <SetProperty Id="GrantConfigDirAcl"
                 Before="GrantConfigDirAcl"
                 Sequence="execute"
                 Value="&quot;[System64Folder]icacls.exe&quot; &quot;[CONFIGDIR]&quot; /grant &quot;NT SERVICE\viam-agent:(OI)(CI)RX&quot;" />

    <CustomAction Id="GrantConfigDirAcl"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <!-- Grant SeCreateSymbolicLinkPrivilege via secedit.
         Uses sc.exe showsid to resolve the virtual-account SID (algorithmic,
         works even before the service has ever run). -->
    <SetProperty Id="GrantSymlinkPrivilege"
                 Before="GrantSymlinkPrivilege"
                 Sequence="execute"
                 Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -ExecutionPolicy Bypass -NonInteractive -Command &quot;$sid = (&amp; sc.exe showsid viam-agent | Where-Object { $_ -match 'SERVICE SID' } | ForEach-Object { $_ -replace '.*:\s*' } | Select-Object -First 1).Trim(); $inf = $env:TEMP + '\viam-secedit.inf'; $db = $env:TEMP + '\viam-secedit.db'; secedit /export /cfg $inf /quiet; $c = Get-Content $inf -Raw -Encoding Default; if ($c -notmatch ('SeCreateSymbolicLinkPrivilege.*' + $sid)) { $c = $c -replace '(SeCreateSymbolicLinkPrivilege\s*=\s*.*)', ('$1,*' + $sid); $c | Set-Content $inf -Encoding Default -NoNewline; Remove-Item $db -EA SilentlyContinue; secedit /configure /db $db /cfg $inf /quiet }; Remove-Item $inf, $db -EA SilentlyContinue&quot;" />

    <CustomAction Id="GrantSymlinkPrivilege"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" />

    <InstallExecuteSequence>
      <Custom Action="DownloadAgent" After="CreateFolders"
              Condition="NOT REMOVE" />
      <Custom Action="CreateSymlink" After="InstallFiles"
              Condition="NOT REMOVE" />
      <Custom Action="RemoveSymlink" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="ConfigureServiceFailure" After="InstallServices"
              Condition="NOT REMOVE" />
      <Custom Action="ConfigureServiceFailureFlag" After="ConfigureServiceFailure"
              Condition="NOT REMOVE" />
      <!-- ConfigPath: update service binary path to include \-\-config -->
      <Custom Action="SetServiceConfigPath" After="InstallServices"
              Condition="NOT REMOVE" />
      <!-- VIAM_HOME env var on the service registry key -->
      <Custom Action="SetViamHomeEnv" After="InstallServices"
              Condition="NOT REMOVE" />
      <!-- ServiceAccount mode: all conditioned on SERVICEACCOUNT=1, run after service is created -->
      <Custom Action="SetServiceAccount" After="InstallServices"
              Condition="NOT REMOVE AND SERVICEACCOUNT = &quot;1&quot;" />
      <Custom Action="GrantRootDirAcl" After="SetServiceAccount"
              Condition="NOT REMOVE AND SERVICEACCOUNT = &quot;1&quot;" />
      <Custom Action="CreateConfigDir" After="GrantRootDirAcl"
              Condition="NOT REMOVE AND SERVICEACCOUNT = &quot;1&quot;" />
      <Custom Action="GrantConfigDirAcl" After="CreateConfigDir"
              Condition="NOT REMOVE AND SERVICEACCOUNT = &quot;1&quot;" />
      <Custom Action="GrantSymlinkPrivilege" After="GrantConfigDirAcl"
              Condition="NOT REMOVE AND SERVICEACCOUNT = &quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- ================================================================
         Windows Service
         ================================================================ -->

    <ComponentGroup Id="AgentService" Directory="BINDIR">
      <!-- GUID changed from B2C3D4E5-… because the KeyPath changed to the file.
           No NeverOverwrite: repair reinstalls the file, then CreateSymlink
           (condition NOT REMOVE, runs on repair too) immediately converts it
           back to a symlink — self-healing without needing NeverOverwrite.
           NeverOverwrite would skip the whole component if a leftover symlink
           exists from a prior failed install, which also skips InstallServices. -->
      <Component Id="ServiceComponent" Guid="B3C4D5E6-F7A8-9012-BCDE-F01234567890">
        <!-- File KeyPath: InstallServices reads the component KeyPath to get the
             service ImagePath. agent-stub.exe is a tiny build-time placeholder;
             CreateSymlink (After=InstallFiles) replaces it with a symlink before
             InstallServices runs (~5800), so the SCM registers
             bin\viam-agent.exe which it then follows to cache\viam-agent-from-installer.exe. -->
        <File Id="AgentBinExe"
              Source="agent-stub.exe"
              Name="viam-agent.exe"
              KeyPath="yes" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Viam\Agent"
                       Name="Installed"
                       Type="integer"
                       Value="1" />

        <!-- Register Application event log source so NT SERVICE\viam-agent
             (a non-admin account) can write events without an Access Denied error.
             Mirrors: New-EventLog -LogName Application -Source "viam-agent"
             Always registered (harmless when running as SYSTEM). -->
        <RegistryKey Root="HKLM"
                     Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\viam-agent">
          <RegistryValue Name="EventMessageFile"
                         Type="expandable"
                         Value="%SystemRoot%\System32\EventCreate.exe" />
        </RegistryKey>

        <ServiceInstall Id="ViamAgentService"
                        Name="viam-agent"
                        DisplayName="Viam Agent"
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Arguments="--viam-dir &quot;[ROOTDIR].&quot;" />

        <ServiceControl Id="StartViamAgent"
                        Name="viam-agent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Firewall Rule (WixFirewall extension)
         ================================================================ -->

    <ComponentGroup Id="FirewallRules" Directory="BINDIR">
      <Component Id="FirewallComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Viam\Agent"
                       Name="FirewallConfigured"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />

        <fw:FirewallException Id="ViamAgentFirewall"
                              Name="Viam Agent"
                              Program="[BINDIR]viam-agent.exe"
                              Scope="any"
                              Protocol="tcp" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Progress text (shown in the installer UI status area)
         ================================================================ -->

    <UI>
      <ProgressText Action="DownloadAgent" Message="Downloading Viam Agent binary..." />
      <ProgressText Action="CreateSymlink" Message="Creating viam-agent symlink..." />
      <ProgressText Action="RemoveSymlink" Message="Removing viam-agent symlink..." />
      <ProgressText Action="ConfigureServiceFailure" Message="Configuring service failure recovery..." />
      <ProgressText Action="ConfigureServiceFailureFlag" Message="Enabling service failure-on-crash flag..." />
      <ProgressText Action="SetServiceConfigPath" Message="Setting agent config path..." />
      <ProgressText Action="SetViamHomeEnv" Message="Setting VIAM_HOME environment variable on service..." />
      <!-- Built-in StartServices can take ~2 minutes waiting for viam-agent to report running -->
      <ProgressText Action="StartServices" Message="Starting Viam Agent service (this may take a minute)..." />
      <!-- ServiceAccount mode steps -->
      <ProgressText Action="SetServiceAccount" Message="Switching service to virtual service account..." />
      <ProgressText Action="GrantRootDirAcl" Message="Granting service account access to install directory..." />
      <ProgressText Action="CreateConfigDir" Message="Creating config directory..." />
      <ProgressText Action="GrantConfigDirAcl" Message="Granting service account access to config directory..." />
      <ProgressText Action="GrantSymlinkPrivilege" Message="Granting SeCreateSymbolicLinkPrivilege..." />
    </UI>

    <!-- ================================================================
         Feature tree
         ================================================================ -->

    <Feature Id="MainFeature" Title="Viam Agent" Level="1">
      <ComponentGroupRef Id="AgentCache" />
      <ComponentGroupRef Id="AgentService" />
      <ComponentGroupRef Id="FirewallRules" />
    </Feature>

  </Package>

</Wix>
